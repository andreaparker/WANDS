# OpenAI API configuration
OPENAI_API_KEY=your_openai_api_key_here

# SPLADE model configuration
SPLADE_QUERY_MODEL_NAME=naver/efficient-splade-V-large-query
SPLADE_DOC_MODEL_NAME=naver/efficient-splade-V-large-doc

# Ranking configuration ; we use cheap models for now!
GPT4_MODEL=gpt-4o-mini              # gpt-4o-mini-2024-07-18
GPT35_MODEL=gpt-4.1-nano-2025-04-14 # gpt-3.5-turbo

# Evaluation configuration
METRICS_K_VALUES=3,5,10
